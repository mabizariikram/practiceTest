pipeline {
    agent any

    parameters {
        choice(name: 'TAG', choices: ['@regression', '@smoke'], description: 'Choisir le tag de test')
        booleanParam(name: 'HTML_REPORT', defaultValue: true, description: 'Générer rapport HTML')
    }

    stages {

        stage('global stage') {

            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.58.2-noble'
                    args '-u root --entrypoint='
                }
            }

            stages {

                stage('Checkout') {
                    steps {
                        // Changer le nom du dossier du repo
                        sh 'rm -rf repoHTML'
                        sh 'git clone https://github.com/mabizariikram/practiceTest.git repoHTML'
                    }
                }

                stage('Install dependencies') {
                    steps {
                        dir('repoHTML') {
                            sh 'npm ci'
                        }
                    }
                }

                stage('Run tests') {
                    steps {
                        dir('repoHTML') {
                            script {
                                sh 'rm -rf playwright-report'

                                if(params.HTML_REPORT){
                                    sh """
                                    npx playwright test \
                                    --grep ${params.TAG} \
                                    --reporter=html
                                    """
                                } else {
                                    sh "npx playwright test --grep ${params.TAG}"
                                }
                            }
                        }
                    }
                }

            }
        }
    }

   post {
    always {
        dir('repoHTML') {
            script {
                // Vérifie si le rapport existe avant d'archiver
                if (fileExists('playwright-report/index.html')) {
                    archiveArtifacts artifacts: 'playwright-report/**', fingerprint: true
                    echo "HTML report archived."

                    // <-- Ajouter ici le publishHTML pour voir le rapport directement dans Jenkins
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'Playwright HTML Report'
                    ])
                } else {
                    echo "No HTML report found to archive."
                }
            }
        }
    }
}

}

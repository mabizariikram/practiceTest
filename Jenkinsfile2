pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/playwright:v1.58.2-noble'
            args '-u root --entrypoint='
        }
    }

    parameters {
        choice(name: 'BROWSER', choices: ['chromium','firefox','webkit'], description: 'Choisir le navigateur')
        booleanParam(name: 'ALLURE', defaultValue: false, description: 'Générer rapport Allure')
        choice(name:'TAG', choices: ['@regression','@smoke','@e2e'], description: 'Choisir le tag')
    }

    stages {
        stage('Clean workspace') {
    steps {
        sh 'rm -rf allure-results || true'
        sh 'rm -rf allure-report || true'
    }
}

        stage('Install dependencies') {
            steps {
                sh 'npm --version'
                sh 'npm install'

                // installer JAVA pour Allure
                sh '''
                apt-get update
                apt-get install -y default-jre
                '''

                // installer allure CLI
                sh 'npm install -g allure-commandline'
            }
        }

        stage('Run Tests') {
            steps {
                script {

                    def reporter = params.ALLURE ? "--reporter=allure-playwright" : ""

                    sh """
                    npx playwright test \
                    --project=${params.BROWSER} \
                    --grep ${params.TAG} \
                    ${reporter}
                    """
                }
            }
        }

    }

    post {
        always {
            script {

                if(params.ALLURE){

                    echo "Generating Allure report"

                    sh '''
                    if [ -d allure-results ]; then
                       allure generate allure-results -o allure-report --clean
                    fi
                    '''

                    archiveArtifacts artifacts: 'allure-report/**', fingerprint: true
                }

            }
        }
    }
}

pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/playwright:v1.58.2-noble'
            args '-u root --entrypoint='
        }
    }

    environment {
        WORKSPACE_DIR = "${env.WORKSPACE}"
    }

    stages {
        stage('Checkout') {
            steps {
                // Clone le dépôt principal
                git url: 'https://github.com/mabizariikram/practiceTest.git', branch: 'master'
            }
        }

        stage('Install & Run Tests') {
            steps {
                dir('repoTEST_showreporter') {
                    // Installe les dépendances Node
                    sh 'npm ci'

                    // Lance les tests Playwright avec le tag @regression et génère le rapport HTML
                    sh 'npx playwright test --grep @regression --reporter=html --output=playwright-report'

                    // Copie le rapport dans le workspace racine pour Jenkins
                    sh "cp -r playwright-report ${WORKSPACE_DIR}/playwright-report"
                }
            }
        }
    }

    post {
        always {
            // Publie le rapport HTML depuis le workspace racine
            publishHTML(target: [
                reportDir: 'playwright-report',   // maintenant au workspace racine
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report',
                keepAll: true,
                allowMissing: false
            ])
        }
    }
}

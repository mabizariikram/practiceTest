pipeline {
    agent any

    parameters {
        choice(name: 'TAG', choices: ['@regression', '@smoke'], description: 'Choisir quel tag exécuter')
        booleanParam(name: 'REPORT', defaultValue: true, description: 'Afficher rapport Playwright')
    }

    environment {
        DOCKER_IMAGE = 'mcr.microsoft.com/playwright:v1.58.2-noble'
    }

    stages {
        stage('Checkout') {
            steps {
                sh 'rm -rf repoTEST_showreporter'
                sh 'git clone https://github.com/mabizariikram/practiceTest.git repoTEST_showreporter'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('repoTEST_showreporter') {
                    sh 'npm ci'
                }
            }
        }

        stage('Run Tests in Docker') {
            steps {
                dir('repoTEST_showreporter') {
                    script {
                        sh 'rm -rf playwright-report'

                        // Exécution des tests dans Docker avec HTML reporter
                        sh 'npx playwright test --grep ${params.TAG} --reporter=html'
                    

                        // Copier le rapport généré vers le workspace principal
                        sh "cp -r playwright-report $WORKSPACE/playwright-report"
                    }
                }
            }
        }

        stage('Debug: lister fichiers') {
            steps {
                sh 'echo "=== Contenu du workspace principal ==="'
                sh 'ls -R $WORKSPACE'
                sh 'echo "Nombre total de fichiers:"'
                sh 'ls -R $WORKSPACE | wc -l'
            }
        }
    }

    post {
        always {
            script {
                if (params.REPORT) {
                    // Publier le rapport HTML
                    publishHTML(target: [
                        reportDir: 'playwright-report',
                        reportFiles: 'index.html',
                        reportName: "Playwright HTML Report",
                        allowMissing: true,
                        alwaysLinkToLastBuild: true
                    ])
                }
            }
        }
    }
}

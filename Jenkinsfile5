pipeline {
    agent any
    parameters {
        choice(name: 'TAG', choices: ['@regression', '@smoke'], description: 'Choisir quel tag exécuter')
        booleanParam(name: 'REPORT', defaultValue: true, description: 'Afficher rapport Playwright HTML')
    }

    stages {
        stage('global stage') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.58.2-noble'
                    args '-u root --entrypoint='
                }
            }

            stages {
                stage('Checkout') {
                    steps {
                        // Supprimer le dossier s'il existe déjà
                        sh 'rm -rf repoTEST_showreporter'
                        // Cloner le dépôt dans le container
                        sh 'git clone https://github.com/mabizariikram/practiceTest.git repoTEST_showreporter'
                    }
                }

                stage('Install Dependencies') {
                    steps {
                        dir('repoTEST_showreporter') {
                            sh 'npm ci'
                        }
                    }
                }

                stage('Run Tests') {
                    steps {
                        dir('repoTEST_showreporter') {
                            script {
                                sh 'rm -rf playwright-report'
                                sh "npx playwright test --grep ${params.TAG} --reporter=html"
                            }
                        }
                    }
                }

                stage('Copy Report to Main Workspace') {
                    steps {
                        // Copier le rapport hors du container Docker vers le workspace principal
                        sh 'cp -r repoTEST_showreporter/playwright-report $WORKSPACE/playwright-report'
                    }
                }

                stage('Debug: lister workspace') {
                    steps {
                        sh 'echo "=== Contenu du workspace principal ==="'
                        sh 'ls -R $WORKSPACE'
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if(params.REPORT) {
                    // Publier le rapport HTML depuis le workspace principal
                    publishHTML(target: [
                        reportDir: 'playwright-report',
                        reportFiles: 'index.html',
                        reportName: "Playwright HTML Report",
                        allowMissing: true,
                        alwaysLinkToLastBuild: true
                    ])
                }
            }
        }
    }
}

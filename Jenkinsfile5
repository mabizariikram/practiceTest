pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/playwright:v1.58.2-noble'
            args '-u root --entrypoint='
        }
    }

    stages {
        stage('Checkout') {
            steps {
                // Clone le dépôt principal
                git url: 'https://github.com/mabizariikram/practiceTest.git', branch: 'master'
            }
        }

        stage('Install & Run Tests') {
            steps {
                dir('repoTEST_showreporter') {
                    // Installe les dépendances Node
                    sh 'npm ci'

                    // Lance les tests Playwright avec le tag @regression
                    // et génère le rapport directement dans le workspace Jenkins
                    sh 'npx playwright test --grep @regression --reporter=html --output=$WORKSPACE/playwright-report'
                }
            }
        }
    }

    post {
        always {
            // Publie le rapport HTML dans Jenkins
            publishHTML(target: [
                reportDir: 'playwright-report',       // le dossier complet contenant index.html et CSS/JS
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report',
                keepAll: true,
                allowMissing: false
            ])

            // Archive les fichiers pour téléchargement si besoin
            archiveArtifacts artifacts: 'playwright-report/**', fingerprint: true
        }
    }
}

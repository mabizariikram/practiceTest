pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'mcr.microsoft.com/playwright:v1.58.2-noble'
    }

    stages {
        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('repoTEST_showreporter') {
                    sh 'npm ci'
                }
            }
        }

        stage('Run Tests in Docker') {
            steps {
                dir('repoTEST_showreporter') {
                    script {
                        // Supprime l'ancien rapport HTML
                        sh 'rm -rf playwright-report'

                        // Exécute les tests Playwright avec reporter HTML
                        sh """
                        docker run --rm -u $(id -u):$(id -g) -v \$(pwd):/work -w /work ${DOCKER_IMAGE} \
                        npx playwright test --grep @regression --reporter=html
                        """

                        // Copier le rapport vers le workspace Jenkins
                        sh 'cp -r playwright-report $WORKSPACE/playwright-report'
                    }
                }
            }
        }
    }

    post {
        always {
            // Publier le rapport HTML Playwright dans Jenkins
            publishHTML(target: [
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: "Playwright HTML Report",
                allowMissing: false,
                alwaysLinkToLastBuild: true
            ])
        }
    }
}

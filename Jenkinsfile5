pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // On supprime l'ancien repo et on clone proprement
                sh 'rm -rf repoTEST_showreporter'
                sh 'git clone https://github.com/mabizariikram/practiceTest.git repoTEST_showreporter'
            }
        }

        stage('Install & Run Tests') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.58.2-noble'
                    args '-u root:root'
                }
            }
            steps {
                dir('repoTEST_showreporter') {
                    // Installer les dépendances
                    sh 'npm ci'

                    // Supprimer l'ancien rapport si existant
                    sh 'rm -rf ../playwright-report'

                    // Lancer les tests et générer le rapport dans ../playwright-report
                    sh 'npx playwright test --grep @regression --reporter=html --output=../playwright-report'
                }
            }
        }
    }

    post {
        always {
            // Publier le rapport HTML depuis le dossier à la racine du job
            publishHTML(target: [
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report'
            ])
        }
    }
}

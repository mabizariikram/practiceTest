pipeline {
    agent any

    parameters {
        choice(name: 'TAG', choices: ['@regression', '@smoke'], description: 'Quel tag exécuter')
        booleanParam(name: 'REPORT', defaultValue: true, description: 'Afficher le rapport Playwright')
    }

    stages {
        stage('Checkout') {
            steps {
                sh 'rm -rf repoTEST_showreporter'
                sh 'git clone https://github.com/mabizariikram/practiceTest.git repoTEST_showreporter'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('repoTEST_showreporter') {
                    sh 'npm ci'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('repoTEST_showreporter') {
                    script {
                        // Supprime l'ancien rapport
                        sh 'rm -rf playwright-report'

                        // Exécute les tests avec reporter HTML (simple)
                        sh "npx playwright test --grep ${params.TAG} --reporter=html"

                        // Copier le rapport vers le workspace Jenkins principal
                        sh 'cp -r playwright-report $WORKSPACE/playwright-report'
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if(params.REPORT){
                    // Publier le rapport HTML dans Jenkins
                    publishHTML(target: [
                        reportDir: 'playwright-report',
                        reportFiles: 'index.html',
                        reportName: "Playwright HTML Report",
                        allowMissing: false,
                        alwaysLinkToLastBuild: true
                    ])
                }
            }
        }
    }
}

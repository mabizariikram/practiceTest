pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                sh 'rm -rf repoTEST_showreporter'
                sh 'git clone https://github.com/mabizariikram/practiceTest.git repoTEST_showreporter'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('repoTEST_showreporter') {
                    sh 'npm ci'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('repoTEST_showreporter') {
                    sh 'rm -rf $WORKSPACE/playwright-report'
                    sh 'npx playwright test --grep @regression --reporter=html --output=$WORKSPACE/playwright-report'
                }
            }
        }
    }

    post {
        always {
            publishHTML(target: [
                reportDir: "$WORKSPACE/playwright-report",
                reportFiles: 'index.html',
                reportName: "Playwright HTML Report",
                allowMissing: false,
                alwaysLinkToLastBuild: true
            ])
        }
    }
}

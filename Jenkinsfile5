pipeline {
    agent any

    parameters {
        choice(name: 'TAG', choices: ['@regression', '@smoke'])
        booleanParam(name: 'REPORT', defaultValue: true, description: 'Afficher rapport Playwright')
    }

    stages {
        stage('global stage') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.58.2-noble'
                    args '-u root --entrypoint='
                }
            }

            stages {
                stage('Checkout') {
                    steps {
                        sh 'rm -rf repoTEST_showreporter'
                        sh 'git clone https://github.com/mabizariikram/practiceTest.git repoTEST_showreporter'
                    }
                }

                stage('install deps') {
                    steps {
                        dir('repoTEST_showreporter') {
                            sh 'npm ci'
                        }
                    }
                }

                stage('run tests') {
                    steps {
                        dir('repoTEST_showreporter') {
                            script {
                                sh 'rm -rf playwright-report'
                                // Exécute les tests avec le reporter HTML
                                sh "npx playwright test --grep ${params.TAG} --reporter=html"
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if(params.REPORT){
                    dir('repoTEST_showreporter') {
                        // Archiver les fichiers (optionnel, pour garder les fichiers)
                        archiveArtifacts artifacts: 'playwright-report/**', fingerprint: true
                        
                        // Publier le rapport HTML pour Jenkins
                        publishHTML(target: [
                            reportDir: 'playwright-report',
                            reportFiles: 'index.html',
                            reportName: "Playwright HTML Report",
                            allowMissing: false,
                            alwaysLinkToLastBuild: true
                        ])
                    }
                }
            }
        }
    }
}

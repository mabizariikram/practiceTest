pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/playwright:v1.58.2-noble'
            args '-u root --entrypoint='
        }
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/mabizariikram/practiceTest.git', branch: 'master'
            }
        }

        stage('Install & Run Tests') {
            steps {
                dir('repoTEST_showreporter') {
                    // Installe les dépendances Node
                    sh 'npm ci'

                    // Lancer les tests Playwright pour le tag @regression et générer le rapport HTML
                    sh 'npx playwright test --grep @regression --reporter=html --output=playwright-report'
                }
            }
        }
    }

    post {
        always {
            // Publier le rapport depuis repoTEST_showreporter/playwright-report
            publishHTML(target: [
                reportDir: 'repoTEST_showreporter/playwright-report',  // chemin correct
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report'
            ])
        }
    }
}
